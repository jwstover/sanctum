# Copy this file to .env.prod_local (gitignored) and fill in the real value.
#
# Get the prod connection string either from the Fly machine:
#   fly ssh console -a sanctum -C "printenv DATABASE_URL"
# or from the Neon dashboard (connection string for the prod database).
PROD_DATABASE_URL=postgres://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Optional — enables the homebrew "Fill from image" card reader.
# ANTHROPIC_API_KEY=sk-ant-...
